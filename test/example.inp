# Comprehensive ORCA input example for syntax highlighting verification
# Covers all 39 blocks and representative ! keyword line entries

# ------------------------------------------------------------------------------
# Simple keyword line
# ------------------------------------------------------------------------------
! B3LYP def2-TZVP def2/J RIJCOSX OPT Freq TightSCF TightOpt D3BJ CPCM(Water)

* xyz 0 1
  C   0.000   0.000   0.000
  H   0.630   0.630   0.630
  H  -0.630  -0.630   0.630
  H  -0.630   0.630  -0.630
  H   0.630  -0.630  -0.630
*

# ------------------------------------------------------------------------------
%pal
  nprocs 8
  nprocs_world 8
end

# ------------------------------------------------------------------------------
%method
  Method        DFT
  Functional    B3LYP
  Exchange      B88
  Correlation   LYP
  FrozenCore    FC_ELECTRONS
  RI            true
  RunTyp        Energy
  ScalHFX       0.20
  ScalDFX       0.72
  ScalGGAC      0.81
  ScalLDAC      1.00
  ScalMP2C      0.27
  D3S6          1.00
  D3A1          0.40
  D3A2          4.36
  D4S6          1.00
  D4A1          0.40
  D4A2          5.00
  D4S8          0.00
  D4S9          1.00
  DoGCP         false
  DFTDOpt       D3BJ
  RangeSepMu    0.33
  RangeSepEXX   0.65
  XAlpha        0.70
  XBeta         0.95
  XKappa        0.46
end

# ------------------------------------------------------------------------------
%scf
  MaxIter       300
  Convergence   Tight
  HFTyp         RHF
  Guess         PModel
  GuessMode     FMatrix
  GuessMix      0.10
  SCFMode       Direct
  ETol          1e-8
  GTol          1e-5
  AutoTRAH      true
  DIIS          true
  DIISMaxEq     15
  DIISStart     0.20
  SOSCF         true
  SOSCFMaxIt    12
  SOSCFStart    0.0033
  TRAH          false
  Damp          0.70
  DampErr       0.05
  LShift        0.25
  ShiftErr      0.01
  Smear         5000
  MaxDisk       8000
  MaxIntMem     2000
  STABPerform   false
  STABNRoots    1
  STABMaxIter   50
  STABRTol      1e-5
  EField        0.0, 0.0, 0.01
  FracOcc       false
  DoMOM         false
  ConvCheckMode 1
  DirectResetFreq 15
  Z_Tol         1e-14
end

# ------------------------------------------------------------------------------
%basis
  Basis         def2-TZVP
  AuxJ          def2/J
  AuxJK         def2/JK
  AuxC          def2-TZVP/C
  ECP           def2-ECP
  Decontract    false
  AutoAux       true
  AutoAuxLmax   6
  AutoAuxSize   medium
  PCDThresh     1e-3
  GTOName       "def2-TZVP"
  GTOAuxJName   "def2/J"
  NewGTO  6
    S   6 1.00
      3047.5249      0.001835
       457.36951     0.014037
       103.94869     0.068843
        29.210155    0.232184
         9.2866630   0.467941
         3.1639270   0.362312
    S   1 1.00
         7.8682724  -0.119332
    end
  AddGTO  1
    S   1 1.00
         0.0360000   1.000000
    end
end

# ------------------------------------------------------------------------------
%geom
  MaxIter          100
  coordsys         redundant
  Convergence      TightOpt
  TolE             1e-6
  TolRMSG          1e-4
  TolMaxG          3e-4
  TolRMSD          2e-3
  TolMaxD          4e-3
  Step             RFO
  Trust            0.30
  MaxStep          0.30
  Update           BFGS
  Calc_Hess        false
  Recalc_Hess      5
  NumHess          false
  Hybrid_Hess      {1,2,3}
  InHess           Almloef
  InHessName       "orca.hess"
  ProjectTR        true
  ReducePrint      false
  UseSOSCF         false
  optimizeHydrogens true
  freezeHydrogens  false
  invertConstraints false
  coordsys         redundant
  modify_internal
    {B 1 2 value 1.5}
  end
  Constraints
    {B 1 2 C}
    {A 1 2 3 C}
  end
  Scan
    B 1 2 = 1.2, 2.0, 9
  end
  BIAS
    B 1 2 = 1.5  K=10.0
  end
  AddExtraBonds true
  AddExtraBonds_MaxDist  3.0
  NResetHess   5
  OptGuess     MORead
end

